%% dart-metaflac CLI command routing
%% Legacy flag categories group ~35 flags; see cli-reference.adoc for the full list.
flowchart TD
    START(["dart run bin/metaflac.dart &lt;args&gt;"])

    DETECT{"First arg is\nsubcommand?"}

    subgraph MODERN["Modern subcommand path"]
        RUNNER["MetaflacCommandRunner"]
        INSPECT["InspectCommand\ninspect"]
        BLOCKS["BlocksCommand\nblocks list"]
        TAGS["TagsCommand\ntags list · set · add\nremove · clear · import · export"]
        PICTURE["PictureCommand\npicture add · remove · export"]
        PADDING["PaddingCommand\npadding set · remove"]
        RUNNER --> INSPECT
        RUNNER --> BLOCKS
        RUNNER --> TAGS
        RUNNER --> PICTURE
        RUNNER --> PADDING
    end

    subgraph LEGACY["Legacy flag path (~35 flags total — see cli-reference.adoc)"]
        SHOWOPS["List &amp; show-ops\n--list · --show-md5sum · --show-sample-rate\n--show-channels · --show-bps · ... (13 flags)"]
        TAGOPS["Tag ops\n--set-tag · --remove-tag · --remove-replay-gain\n--remove-all-tags-except · --import-tags-from · ... (9 flags)"]
        PICOPS["Picture ops\n--import-picture-from · --export-picture-to"]
        GLOBALOPTS["Global options\n-o/--output-name · --preserve-modtime\n--dont-use-padding · --no-utf8-convert · ... (10 flags)"]
    end

    EXECUTE["Execute mutations /\nread operations"]

    OUTPUT(["stdout\n(text or JSON)"])

    START --> DETECT
    DETECT -- Yes --> RUNNER
    DETECT -- No  --> SHOWOPS
    DETECT -- No  --> TAGOPS
    DETECT -- No  --> PICOPS
    DETECT -- No  --> GLOBALOPTS

    INSPECT  --> EXECUTE
    BLOCKS   --> EXECUTE
    TAGS     --> EXECUTE
    PICTURE  --> EXECUTE
    PADDING  --> EXECUTE
    SHOWOPS  --> EXECUTE
    TAGOPS   --> EXECUTE
    PICOPS   --> EXECUTE
    GLOBALOPTS --> EXECUTE

    EXECUTE --> OUTPUT
